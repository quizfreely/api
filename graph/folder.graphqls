type FolderEdge {
    node: Folder!
    cursor: String!
}

type FolderConnection {
    edges: [FolderEdge!]!
    pageInfo: PageInfo!
}

type Folder {
    id: ID!
    name: String!
    studysets(first: Int = 24, after: String, last: Int, before: String): StudysetConnection!
    studysetDrafts(first: Int = 24, after: String, last: Int, before: String): StudysetConnection!
    studysetCount: Int!
    user: User
}
